# 所有文本文件统一使用 LF，入库时自动转换
* text=auto eol=lf

# 强制 Shell 脚本必须 LF (避免 Linux/macOS 执行报错)
*.sh text eol=lf

# Windows 批处理保持 CRLF (更兼容)
*.bat text eol=crlf
*.cmd text eol=crlf

# PowerShell 脚本可选，但建议 LF (新版 PowerShell 支持)
*.ps1 text eol=lf

# Rust 相关
*.rs text eol=lf
*.toml text eol=lf
Cargo.lock text eol=lf

# 前端
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# 标记二进制文件（防止损坏）
*.png binary
*.jpg binary
*.ico binary
*.zip binary
*.gz binary
*.jar binary
*.node binary  # 原生 Node 模块
*.dll binary
*.so binary
*.dylib binary