{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rdata-station",
  "version": "0.1.0",
  "identifier": "com.sling.rdata-station",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1425",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rdata-station",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; font-src 'self'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
