{
  "driverId": "postgres",
  "driverName": "PostgreSQL",
  "version": "16.0",
  "metadata": {
    "category": "relational",
    "description": "PostgreSQL 强大的开源关系型数据库",
    "features": ["事务", "视图", "存储过程", "触发器", "JSON 支持", "全文搜索"],
    "defaultPort": 5432,
    "requireFile": false,
    "supportsSsl": true,
    "supportsSshTunnel": true
  },
  "sections": [
    {
      "key": "connection",
      "title": "连接设置",
      "icon": "database",
      "fields": [
        {
          "key": "host",
          "label": "主机",
          "type": "text",
          "placeholder": "localhost",
          "required": true,
          "default": "localhost"
        },
        {
          "key": "port",
          "label": "端口",
          "type": "number",
          "placeholder": "5432",
          "required": true,
          "default": 5432
        },
        {
          "key": "database",
          "label": "数据库",
          "type": "text",
          "placeholder": "postgres",
          "required": true
        }
      ]
    },
    {
      "key": "auth",
      "title": "身份验证",
      "icon": "user",
      "fields": [
        {
          "key": "username",
          "label": "用户名",
          "type": "text",
          "placeholder": "postgres"
        },
        {
          "key": "password",
          "label": "密码",
          "type": "password",
          "placeholder": "输入密码"
        }
      ]
    },
    {
      "key": "ssh",
      "title": "SSH 隧道",
      "icon": "shield",
      "collapsible": true,
      "collapsed": true,
      "enableField": "enableSsh",
      "fields": [
        {
          "key": "enableSsh",
          "label": "启用 SSH 隧道",
          "type": "checkbox",
          "default": false
        },
        {
          "key": "sshHost",
          "label": "SSH 主机",
          "type": "text",
          "placeholder": "ssh.example.com"
        },
        {
          "key": "sshPort",
          "label": "SSH 端口",
          "type": "number",
          "default": 22
        },
        {
          "key": "sshUsername",
          "label": "SSH 用户名",
          "type": "text",
          "placeholder": "username"
        },
        {
          "key": "sshPassword",
          "label": "SSH 密码",
          "type": "password",
          "placeholder": "输入 SSH 密码"
        }
      ]
    },
    {
      "key": "ssl",
      "title": "SSL/TLS",
      "icon": "lock",
      "collapsible": true,
      "collapsed": true,
      "enableField": "enableSsl",
      "fields": [
        {
          "key": "enableSsl",
          "label": "启用 SSL",
          "type": "checkbox",
          "default": false
        },
        {
          "key": "sslCa",
          "label": "CA 证书",
          "type": "file",
          "placeholder": "选择 CA 证书文件"
        },
        {
          "key": "sslCert",
          "label": "客户端证书",
          "type": "file",
          "placeholder": "选择客户端证书文件"
        },
        {
          "key": "sslKey",
          "label": "客户端密钥",
          "type": "file",
          "placeholder": "选择客户端密钥文件"
        }
      ]
    },
    {
      "key": "advanced",
      "title": "高级选项",
      "icon": "settings",
      "collapsible": true,
      "collapsed": true,
      "fields": [
        {
          "key": "sslMode",
          "label": "SSL 模式",
          "type": "select",
          "default": "prefer",
          "options": [
            { "label": "禁用", "value": "disable" },
            { "label": "允许", "value": "allow" },
            { "label": "优先", "value": "prefer" },
            { "label": "要求", "value": "require" },
            { "label": "验证 CA", "value": "verify-ca" },
            { "label": "完全验证", "value": "verify-full" }
          ]
        },
        {
          "key": "applicationName",
          "label": "应用名称",
          "type": "text",
          "placeholder": "RdataStation"
        },
        {
          "key": "connectTimeout",
          "label": "连接超时 (秒)",
          "type": "number",
          "default": 10
        }
      ]
    }
  ],
  "navigation": {
    "hasCatalogs": true,
    "hasSchemas": true,
    "systemSchemas": ["information_schema", "pg_catalog", "pg_toast"],
    "folders": {
      "tables":       { "enabled": true, "label": "Tables",      "icon": "table",    "childTypes": ["table"] },
      "views":        { "enabled": true, "label": "Views",       "icon": "eye",      "childTypes": ["view"] },
      "functions":    { "enabled": true, "label": "Functions",   "icon": "function", "childTypes": ["function"] },
      "procedures":   { "enabled": true, "label": "Procedures",  "icon": "terminal", "childTypes": ["procedure"] },
      "sequences":    { "enabled": true, "label": "Sequences",   "icon": "hash",     "childTypes": [] },
      "triggers":     { "enabled": true, "label": "Triggers",    "icon": "zap",      "childTypes": [] }
    },
    "tableChildren": {
        "columns": true,
        "indexes": false,
        "constraints": false,
        "triggers": true,
        "foreignKeys": false,
        "references": false
      }
  }
}
